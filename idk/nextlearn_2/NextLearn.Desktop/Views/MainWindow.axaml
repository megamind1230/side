<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NextLearn.Desktop.ViewModels"
        xmlns:sys="using:System"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ae="using:AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="NextLearn.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="NextLearn - Let's Fight Distraction"
        Width="900" Height="650"
        MinWidth="600" MinHeight="400"
        KeyDown="OnKeyDown">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- Main content panels -->
        <Panel IsVisible="{Binding IsEditorOpen}">
            <DockPanel Background="#F8FAFC">
                <DockPanel DockPanel.Dock="Top" Margin="24,24,24,0">
                    <Button DockPanel.Dock="Left" Content="Close" Command="{Binding EditorViewModel.CloseCommand}" Padding="16,8"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                        <Button Content="Save" Command="{Binding EditorViewModel.SaveCommand}" Padding="16,8"/>
                        <Button Content="Import to Deck" Command="{Binding EditorViewModel.ImportToDeckCommand}" Background="#10B981" Foreground="White" Padding="16,8"/>
                    </StackPanel>
                    <TextBlock Text="{Binding EditorViewModel.DeckTitle}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </DockPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding EditorViewModel.StatusMessage}" Foreground="#64748B" Margin="24,0,24,12"/>

                <Border Background="White" CornerRadius="16" Padding="24" Margin="24" 
                        VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <TextBox Text="{Binding EditorViewModel.MarkdownContent}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas,Monospace"
                             FontSize="14"
                             Watermark="Edit markdown here..."/>
                </Border>
            </DockPanel>
        </Panel>

        <Panel IsVisible="{Binding IsLearning}">
            <DockPanel Background="#1E293B">
                <!-- Row 1: DeckTitle -->
                <Border DockPanel.Dock="Top" Padding="16,12" Background="#1E293B">
                    <DockPanel>
                        <Button DockPanel.Dock="Left" Command="{Binding ExitLearningCommand}" 
                                Background="Transparent" Padding="12,8">
                            <TextBlock Text="←" FontSize="20" Foreground="#94A3B8"/>
                        </Button>
                        <Button DockPanel.Dock="Right" Command="{Binding ToggleSidebarCommand}"
                                Background="Transparent" Padding="12,8">
                            <TextBlock Text="☰" FontSize="20" Foreground="#94A3B8"/>
                        </Button>
                        <Button DockPanel.Dock="Right" Content="Edit" Command="{Binding OpenEditorCommand}"
                                Background="Transparent" Foreground="#94A3B8" Padding="12,8" FontSize="14"/>
                        <TextBlock Text="{Binding LearningViewModel.DeckTitle}" FontSize="16"
                                   FontWeight="SemiBold" Foreground="#E2E8F0" HorizontalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Bottom bar with prev/next and page count -->
                <Border DockPanel.Dock="Bottom" Padding="24,12" Background="#1E293B">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Page counter - bottom left -->
                        <Border Grid.Column="0" Background="#0D9488" CornerRadius="8" Padding="12,6" 
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding LearningViewModel.ProgressText}" FontSize="14" 
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <!-- Prev / Next buttons - bottom right -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                            <Button Classes="Faded" Content="← Previous" Command="{Binding LearningViewModel.PreviousPageCommand}"
                                    IsEnabled="{Binding LearningViewModel.CanGoBack}" Padding="20,12"
                                    Background="#334155" Foreground="#94A3B8"/>
                            <Button Content="{Binding LearningViewModel.NextButtonText}" Command="{Binding LearningViewModel.CompleteAndGoHomeCommand}"
                                    Background="{Binding LearningViewModel.NextButtonColor}" Foreground="White" Padding="48,16" FontSize="18"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main content area: 3-row grid so the middle row = 60% of available height -->
                <!-- Rows: 20% top padding | 60% content | 20% bottom padding -->
                <!-- Columns: 5% edge | 45% content | 10% gap | 45% image | 5% edge -->
                <Grid RowDefinitions="0.6*,3*,0.4*" ColumnDefinitions="2*,45*,6*,45*,2*">

                    <!-- LEFT: teal content box with AvaloniaEdit -->
                    <Border Grid.Row="1" Grid.Column="1"
                            Background="#0D9488" CornerRadius="12" Padding="0"
                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Padding="16,8" Background="#0B7E72"
                                    CornerRadius="12,12,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <TextBlock Text="{Binding LearningViewModel.CurrentSectionBreadcrumb}"
                                               FontSize="15" Foreground="#94A3B8"
                                               IsVisible="{Binding LearningViewModel.HasSection}"/>
                                    <TextBlock Text=" → " FontSize="15" Foreground="#64748B"
                                               IsVisible="{Binding LearningViewModel.HasSection}"/>
                                    <TextBlock Text="{Binding LearningViewModel.CurrentPageBreadcrumb}"
                                               FontSize="15" Foreground="#E2E8F0"/>
                                </StackPanel>
                            </Border>
                            <ae:TextEditor x:Name="ContentEditor"
                                           Grid.Row="1"
                                           IsReadOnly="True"
                                           ShowLineNumbers="False"
                                           WordWrap="True"
                                            FontSize="16"
                                            Background="#1E293B"
                                            HorizontalScrollBarVisibility="Disabled"
                                            VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Border>

                    <!-- RIGHT: image placeholder -->
                    <Border Grid.Row="1" Grid.Column="3"
                            Background="#334155" CornerRadius="12"
                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <TextBlock Text="img" FontSize="32" Foreground="#64748B"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </DockPanel>
        </Panel>

        <Panel IsVisible="{Binding !IsLearning}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#2563EB" Padding="16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="NextLearn" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Let's Fight Distraction" FontSize="14" Foreground="#BFDBFE" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <DockPanel DockPanel.Dock="Right">
                            <Button DockPanel.Dock="Right" Command="{Binding ToggleSidebarCommand}" Background="Transparent" Padding="12,8">
                                <TextBlock Text="☰" FontSize="20" Foreground="White"/>
                            </Button>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="Marketplace" Command="{Binding NavigateToMarketplaceCommand}" Background="Transparent" Foreground="White" Padding="12,8"/>
                                <Button Content="Get Plugins" Command="{Binding NavigateToPluginsCommand}" Background="Transparent" Foreground="White" Padding="12,8"/>
                            </StackPanel>
                        </DockPanel>
                    </DockPanel>
                </Border>

                <Panel Margin="24">
                    <Panel IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.IsNull}}">
                        <TextBlock Text="Loading..." HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Panel>

                    <ScrollViewer x:Name="HomeScrollViewer" IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Spacing="24">
                            <StackPanel Spacing="8">
                                <TextBlock Text="What do you want to learn?" FontSize="28" FontWeight="Bold"/>
                                <TextBlock Text="Choose a deck and start learning" FontSize="16" Foreground="#64748B"/>
                            </StackPanel>

                            <TextBox x:Name="HomeSearchBox" Text="{Binding HomeViewModel.SearchText}" Watermark="Search by title, description, or #tag..." Padding="12" FontSize="16"/>

                            <ItemsControl ItemsSource="{Binding HomeViewModel.Decks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                                                BorderBrush="#334155" BorderThickness="1">
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                                                    <Button Content="Learn" 
                                                            Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).NavigateToLearningCommand}"
                                                            CommandParameter="{Binding Id}" 
                                                            Background="#2563EB" Foreground="White" Padding="16,8"/>
                                                </StackPanel>
                                                    <StackPanel Margin="0,0,24,0">
                                                        <DockPanel>
                                                             <TextBlock DockPanel.Dock="Right" Text="{Binding Title}" FontSize="14" Foreground="#E2E8F0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                                            <TextBlock FontSize="13" Foreground="#FBBF24" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                                                <Run Text="Name: "/>
                                                                <Run Text="{Binding FileName}"/>
                                                            </TextBlock>
                                                         </DockPanel>
                                                         <TextBlock Text="{Binding Description}" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                                        <TextBlock Foreground="#94A3B8" FontSize="13">
                                                            <Run Text="{Binding PageCount, StringFormat='{}{0} pages'}"/>
                                                            <Run Text=" | "/>
                                                            <Run Text="{Binding Tags}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Panel>
            </DockPanel>
        </Panel>

        <!-- Search popups - ALWAYS ON TOP (last in Panel) -->
        <Panel IsVisible="{Binding LearningViewModel.ShowSearch}" ZIndex="100">
            <Border Background="#80000000">
                <Border Background="#06B6D4" CornerRadius="16" Padding="24" Margin="100" 
                        VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600" MaxHeight="500">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                            <Button DockPanel.Dock="Right" Content="X" Command="{Binding LearningViewModel.ToggleSearchCommand}" Padding="8,4" Background="White"/>
                            <TextBlock Text="Search in deck (Enter to open in neovim)" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        </DockPanel>
                        <TextBox x:Name="DeckSearchBox" Text="{Binding LearningViewModel.SearchText}" 
                                 Watermark="Type to search..." FontSize="16" Padding="12" Margin="0,0,0,12" Background="White"/>
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding LearningViewModel.SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F1F5F9" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding TextContent}" Foreground="#64748B" FontSize="12" 
                                                           TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Border>
        </Panel>

        <!-- Right sidebar overlay -->
        <Panel IsVisible="{Binding IsSidebarOpen}" ZIndex="200">
            <Border Background="#80000000" PointerPressed="CloseSidebarOnBackdrop">
                <Border Background="#1E293B" Width="280" HorizontalAlignment="Right"
                        BorderBrush="#334155" BorderThickness="1,0,0,0">
                    <StackPanel Spacing="16" Margin="20">
                        <!-- Header -->
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Command="{Binding ToggleSidebarCommand}"
                                    Background="Transparent" Padding="6">
                                <TextBlock Text="✕" FontSize="16" Foreground="#94A3B8"/>
                            </Button>
                            <TextBlock Text="Sidebar" FontSize="20" FontWeight="Bold" Foreground="#E2E8F0" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </DockPanel>
                        <Border Height="1" Background="#334155"/>

                        <!-- User info placeholder -->
                        <TextBlock Text="User" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                        <TextBlock Text="Signed in (activity stats coming soon)" FontSize="12" Foreground="#94A3B8"/>

                        <Border Height="1" Background="#334155"/>

                        <Button Command="{Binding OpenSettingsCommand}"
                                Background="#334155" Foreground="#E2E8F0" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="⚙" FontSize="18" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <TextBlock Text="  Settings" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Border>
        </Panel>

        <!-- Settings page overlay -->
        <Panel IsVisible="{Binding IsSettingsOpen}" ZIndex="300">
            <DockPanel Background="#1E293B">
                <Border DockPanel.Dock="Top" Padding="16,12" Background="#1E293B">
                    <DockPanel>
                        <Button Command="{Binding CloseSettingsCommand}"
                                Background="Transparent" Padding="12,8">
                            <TextBlock Text="← Back" FontSize="16" Foreground="#94A3B8"/>
                        </Button>
                        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="#E2E8F0" VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </DockPanel>
                </Border>
                <ScrollViewer Margin="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Editor" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                        <ComboBox SelectedItem="{Binding Editor}" FontSize="13"
                                  Foreground="#E2E8F0" Background="#1E293B" BorderBrush="#334155">
                            <ComboBox.Items>
                                <sys:String>neovim</sys:String>
                                <sys:String>vscode</sys:String>
                                <sys:String>emacs</sys:String>
                                <sys:String>sublime</sys:String>
                            </ComboBox.Items>
                        </ComboBox>

                        <Border Height="1" Background="#334155"/>

                        <TextBlock Text="Theme" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                        <ComboBox SelectedItem="{Binding Theme}" FontSize="13"
                                  Foreground="#E2E8F0" Background="#1E293B" BorderBrush="#334155">
                            <ComboBox.Items>
                                <sys:String>Dark</sys:String>
                                <sys:String>Light</sys:String>
                            </ComboBox.Items>
                        </ComboBox>

                        <Border Height="1" Background="#334155"/>

                        <TextBlock Text="Font" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                        <TextBox Text="{Binding Font}" Watermark="Inter"
                                 Padding="8" FontSize="13" Foreground="#E2E8F0"
                                 Background="#1E293B" BorderBrush="#334155"/>

                        <Border Height="1" Background="#334155"/>

                        <TextBlock Text="Decks Path (restart required)" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                        <TextBox Text="{Binding DecksPath}" Watermark="~/nextlearn/decks"
                                 Padding="8" FontSize="13" Foreground="#E2E8F0"
                                 Background="#1E293B" BorderBrush="#334155"/>

                        <Border Height="1" Background="#334155"/>

                        <TextBlock Text="{Binding SettingsStatus}" FontSize="13" Foreground="#10B981"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                            <Button Command="{Binding SaveSettingsCommand}" Background="#0D9488"
                                    Foreground="White" Padding="24,10" FontSize="14"
                                    Content="Save"/>
                            <Button Command="{Binding ResetSettingsCommand}" Background="#334155"
                                    Foreground="#94A3B8" Padding="24,10" FontSize="14"
                                    Content="Reset to defaults"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Panel>
    </Panel>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#CBD5E1"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#94A3B8"/>
        </Style>
        <!-- Previous button styles - dimmed -->
        <Style Selector="Button.Faded">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>
        <Style Selector="Button.Faded:pointerover">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style Selector="Button.Faded:pressed">
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>
    </Window.Styles>

</Window>
