<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MindmapDotnet.App.ViewModels"
        xmlns:ctl="using:MindmapDotnet.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="MindmapDotnet.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Icon="/Assets/avalonia-logo.ico"
        MinWidth="600" MinHeight="400"
        Background="#1a1a2e"
        KeyboardNavigation.TabNavigation="None">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid x:Name="ContentArea">

    <!-- Mindmap Canvas -->
    <ctl:MindmapCanvas x:Name="Canvas" IsVisible="{Binding IsMindmapView}" Focusable="True"
                   KeyboardNavigation.TabNavigation="None"/>

    <!-- Markdown Editor -->
    <TextBox x:Name="MarkdownEditor"
             IsVisible="{Binding IsMarkdownView}"
             Text="{Binding MarkdownText, Mode=TwoWay}"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             FontFamily="Consolas, 'Cascadia Code', monospace"
             FontSize="13"
             Background="#1e1e2e"
             Foreground="#cdd6f4"
             BorderThickness="0"/>

    <!-- Inline Edit Overlay -->
    <TextBox x:Name="EditBox"
             IsVisible="False"
             IsTabStop="False"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             AcceptsReturn="False"
             TextWrapping="NoWrap"
             FontSize="13"
             Padding="8,4"
             BorderThickness="1.5"
             BorderBrush="#89b4fa"
             Background="#45475a"
             Foreground="#cdd6f4"
             CaretBrush="#cdd6f4"/>

    <!-- Help Overlay -->
    <Border x:Name="HelpOverlay"
            IsVisible="False"
            Background="#cc1e1e2e"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="12"
            BorderThickness="1"
            BorderBrush="#45475a"
            Padding="36,28">
      <StackPanel Spacing="8">
        <TextBlock Text="MindmapDotnet Shortcuts" FontSize="20" FontWeight="Bold"
                   Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="i" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="  —  Edit node text"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="g i" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="  —  Overwrite node text"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Tab" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="       —  Create child node"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Enter" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="     —  Create sibling node"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Esc" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="       —  Commit &amp; exit edit"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Del/Bksp" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="  —  Delete node (cascade)"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="← ↑ → ↓" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="  —  Navigate tree"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="?" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="          —  Toggle this help"/>
        </TextBlock>
        <Rectangle Height="1" Fill="#45475a" Margin="0,8"/>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Ctrl+Z" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="    —  Undo"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Ctrl+Y" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="    —  Redo"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Ctrl+M" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="    —  Toggle markdown view"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Ctrl+L" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="    —  Toggle layout"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Ctrl+S" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="    —  Save"/>
        </TextBlock>
        <TextBlock FontSize="14" Foreground="#a6adc8">
          <Run Text="Ctrl+O" FontWeight="Bold" Foreground="#89b4fa"/>
          <Run Text="    —  Open"/>
        </TextBlock>
      </StackPanel>
    </Border>

  </Grid>
</Window>
