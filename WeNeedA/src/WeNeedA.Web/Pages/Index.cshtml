@page
@model IndexModel
@{
    ViewData["Title"] = "Find People by Region & Profession";
}

<div class="text-center mb-5">
    <h1 class="display-4"><i class="bi bi-people-fill text-primary"></i> WeNeedA</h1>
    <p class="lead text-muted">Find skilled people in your area — browse by region and profession</p>
</div>

<div class="row mb-4">
    <div class="col-md-6 mx-auto">
        <div class="input-group">
            <input type="text" class="form-control form-control-lg" placeholder="Search by name, profession, or location..." id="searchInput">
            <button class="btn btn-primary btn-lg" type="button"><i class="bi bi-search"></i> Search</button>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-globe"></i> Browse by Country</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var country in Model.Countries)
                    {
                        <div class="col-md-4 col-lg-3 mb-3">
                            <a asp-page="/Locations/Country" asp-route-slug="@country.Slug" class="text-decoration-none">
                                <div class="card h-100 border-primary">
                                    <div class="card-body text-center">
                                        <i class="bi bi-geo-alt-fill text-primary" style="font-size: 2rem;"></i>
                                        <h5 class="card-title mt-2">@country.Name</h5>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card border-success h-100">
            <div class="card-body text-center">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                <h5 class="card-title">Verified People</h5>
                <p class="card-text text-muted">Browse listings from verified professionals</p>
                <a asp-page="/Verified" class="btn btn-success">Browse Verified</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card border-warning h-100">
            <div class="card-body text-center">
                <i class="bi bi-exclamation-circle-fill text-warning" style="font-size: 2rem;"></i>
                <h5 class="card-title">Unverified People</h5>
                <p class="card-text text-muted">Browse listings from new/unverified users</p>
                <a asp-page="/NotVerified" class="btn btn-warning">Browse Unverified</a>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <a asp-page="/Tags/Index" class="btn btn-outline-primary"><i class="bi bi-tags"></i> Browse All Profession Tags</a>
</div>
