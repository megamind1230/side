@page "/country/{slug}"
@model CountryModel
@{
    ViewData["Title"] = Model.Country?.Name ?? "Not Found";
}

@if (Model.Country == null)
{
    <div class="alert alert-danger">Country not found.</div>
    return;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item active">@Model.Country.Name</li>
    </ol>
</nav>

<h2><i class="bi bi-globe text-primary"></i> @Model.Country.Name</h2>
<p class="text-muted">Select a governorate to browse</p>

<div class="row">
    @foreach (var gov in Model.Governorates)
    {
        <div class="col-md-4 col-lg-3 mb-3">
            <a asp-page="/Locations/Governorate" asp-route-slug="@gov.Slug" class="text-decoration-none">
                <div class="card h-100 border-info">
                    <div class="card-body text-center">
                        <i class="bi bi-building text-info" style="font-size: 1.5rem;"></i>
                        <h5 class="card-title mt-2">@gov.Name</h5>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
