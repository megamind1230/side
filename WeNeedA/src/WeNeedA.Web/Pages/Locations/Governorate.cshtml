@page "/governorate/{slug}"
@model GovernorateModel
@{
    ViewData["Title"] = Model.Governorate?.Name ?? "Not Found";
}

@if (Model.Governorate == null)
{
    <div class="alert alert-danger">Governorate not found.</div>
    return;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Locations/Country" asp-route-slug="@Model.Governorate.Country.Slug">@Model.Governorate.Country.Name</a></li>
        <li class="breadcrumb-item active">@Model.Governorate.Name</li>
    </ol>
</nav>

<h2><i class="bi bi-building text-info"></i> @Model.Governorate.Name</h2>
<p class="text-muted">Select a city to browse</p>

<div class="row">
    @foreach (var city in Model.Cities)
    {
        <div class="col-md-4 col-lg-3 mb-3">
            <a asp-page="/Locations/City" asp-route-slug="@city.Slug" class="text-decoration-none">
                <div class="card h-100 border-secondary">
                    <div class="card-body text-center">
                        <i class="bi bi-house-door text-secondary" style="font-size: 1.5rem;"></i>
                        <h5 class="card-title mt-2">@city.Name</h5>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
