@page "/city/{slug}"
@model CityModel
@{
    ViewData["Title"] = Model.City?.Name ?? "Not Found";
}

@if (Model.City == null)
{
    <div class="alert alert-danger">City not found.</div>
    return;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Locations/Country" asp-route-slug="@Model.City.Governorate.Country.Slug">@Model.City.Governorate.Country.Name</a></li>
        <li class="breadcrumb-item"><a asp-page="/Locations/Governorate" asp-route-slug="@Model.City.Governorate.Slug">@Model.City.Governorate.Name</a></li>
        <li class="breadcrumb-item active">@Model.City.Name</li>
    </ol>
</nav>

<h2><i class="bi bi-house-door text-secondary"></i> @Model.City.Name</h2>
<p class="text-muted">Select a village/area to browse</p>

<div class="row">
    @foreach (var village in Model.Villages)
    {
        <div class="col-md-4 col-lg-3 mb-3">
            <a asp-page="/Locations/Village" asp-route-slug="@village.Slug" class="text-decoration-none">
                <div class="card h-100 border-success">
                    <div class="card-body text-center">
                        <i class="bi bi-signpost-2 text-success" style="font-size: 1.5rem;"></i>
                        <h5 class="card-title mt-2">@village.Name</h5>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
