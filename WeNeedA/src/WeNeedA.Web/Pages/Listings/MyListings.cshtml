@page "/mylistings"
@model MyListingsModel
@{
    ViewData["Title"] = "My Listings";
}

<h2><i class="bi bi-list-ul text-primary"></i> My Listings</h2>
<p class="text-muted">All listings you have created</p>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<p>
    <a asp-page="/Listings/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create New Listing</a>
</p>

@if (!Model.Listings.Any())
{
    <div class="alert alert-info">You haven't created any listings yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Village</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var listing in Model.Listings)
                {
                    <tr>
                        <td>@listing.Name</td>
                        <td>@listing.Village.Name</td>
                        <td>
                            @if (listing.VerificationStatus == VerificationStatus.Verified)
                            {
                                <span class="badge bg-success">Verified</span>
                            }
                            else if (listing.VerificationStatus == VerificationStatus.Admin)
                            {
                                <span class="badge bg-primary">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Unverified</span>
                            }
                        </td>
                        <td>@listing.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td><a asp-page="/Listings/Details" asp-route-id="@listing.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
