@page "/tags"
@model WeNeedA.Web.Pages.Tags.IndexModel
@{
    ViewData["Title"] = "Profession Tags";
}

<h2><i class="bi bi-tags text-primary"></i> All Profession Tags</h2>
<p class="text-muted">Browse people by their profession, craft, or service type</p>

<div class="row">
    @foreach (var tag in Model.Tags)
    {
        <div class="col-md-3 col-lg-2 mb-3">
            <div class="card h-100 text-center border-info">
                <div class="card-body">
                    <i class="bi bi-person-badge text-info" style="font-size: 1.5rem;"></i>
                    <h6 class="card-title mt-2">@tag.Name</h6>
                    <a asp-page="/Tags/Listings" asp-route-slug="@tag.Slug" class="btn btn-sm btn-outline-info">Browse</a>
                </div>
            </div>
        </div>
    }
</div>
