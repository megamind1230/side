@page "/tags/{slug}"
@model WeNeedA.Web.Pages.Tags.ListingsModel
@{
    ViewData["Title"] = $"People - {Model.Tag?.Name}" ?? "Not Found";
}

@if (Model.Tag == null)
{
    <div class="alert alert-danger">Tag not found.</div>
    return;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Tags/Index">Tags</a></li>
        <li class="breadcrumb-item active">@Model.Tag.Name</li>
    </ol>
</nav>

<h2><i class="bi bi-person-badge text-info"></i> @Model.Tag.Name</h2>
<p class="text-muted">People listing this as their profession</p>

@if (!Model.Listings.Any())
{
    <div class="alert alert-info">No people listed with this profession yet.</div>
}
else
{
    <div class="row">
        @foreach (var listing in Model.Listings)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2" style="width: 48px; height: 48px; font-size: 1.2rem;">
                                @listing.Name[0]
                            </div>
                            <div>
                                <h5 class="card-title mb-0">@listing.Name</h5>
                                @if (listing.VerificationStatus == VerificationStatus.Verified)
                                {
                                    <span class="badge bg-success">Verified</span>
                                }
                                else if (listing.VerificationStatus == VerificationStatus.Admin)
                                {
                                    <span class="badge bg-primary">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Unverified</span>
                                }
                            </div>
                        </div>
                        <p class="card-text small text-muted">
                            <i class="bi bi-geo-alt"></i> @listing.Village.Name, @listing.Village.City.Name
                        </p>
                        <a asp-page="/Listings/Details" asp-route-id="@listing.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
