@page "/identity/account/verifyssid"
@namespace WeNeedA.Web.Areas.Identity.Pages.Account
@model VerifySsidModel
@{
    ViewData["Title"] = "Verify National ID (SSID)";
}

<h2><i class="bi bi-shield-check text-primary"></i> Identity Verification</h2>
<p class="text-muted">Submit your national ID (SSID) number to get verified. An admin will review and approve your verification.</p>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

@if (Model.CurrentUser.IsSsidVerified)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill"></i> Your identity is already verified!
    </div>
}
else if (!string.IsNullOrEmpty(Model.CurrentUser.SsidNumber))
{
    <div class="alert alert-info">
        <i class="bi bi-clock-fill"></i> Your SSID (<strong>@Model.CurrentUser.SsidNumber</strong>) is pending admin review.
    </div>
}
else
{
    <form method="post">
        <div class="mb-3">
            <label asp-for="Input.SsidNumber" class="form-label">National ID / SSID Number</label>
            <input asp-for="Input.SsidNumber" class="form-control" required pattern="[0-9]{14}" title="Enter a 14-digit national ID number" />
            <span asp-validation-for="Input.SsidNumber" class="text-danger"></span>
            <div class="form-text">Enter your 14-digit national ID number for verification.</div>
        </div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Submit for Verification</button>
    </form>
}
