<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NextLearn.Desktop.ViewModels"
             x:Class="NextLearn.Desktop.Controls.MarketplacePanel"
             x:DataType="vm:MainWindowViewModel">
    <Panel IsVisible="{Binding IsMarketplaceOpen}" ZIndex="310">
        <DockPanel Background="#1E293B">
            <Border DockPanel.Dock="Top" Padding="16,12" Background="#1E293B">
                <DockPanel>
                    <Button Command="{Binding CloseMarketplaceCommand}"
                            Background="Transparent" Padding="12,8">
                        <TextBlock Text="← Back" FontSize="16" Foreground="#94A3B8"/>
                    </Button>
                </DockPanel>
            </Border>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Margin="48">
                <TextBlock Text="Marketplace coming soon in later updates.." FontSize="24" FontWeight="Bold"
                           Foreground="#E2E8F0" TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock Text="you can share notes with Telegram, 0x0.st, google drive ..etc for now"
                           FontSize="16" Foreground="#94A3B8" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </DockPanel>
    </Panel>
</UserControl>
